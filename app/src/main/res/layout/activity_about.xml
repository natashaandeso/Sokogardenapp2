<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:background="#C7AFA973"
    android:layout_height="match_parent"
    tools:context=".About">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=" About Us 📜"
        android:textStyle="bold"
        android:textSize="40sp"
        android:textColor="#542E2E"
        android:textAlignment="center"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="20dp"
        app:cardElevation="15dp"
        android:padding="10dp"
        app:cardCornerRadius="15dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_margin="10dp"
            android:background="#B1872C74"
            android:padding="10dp">

            <TextView
                android:id="@+id/aboutTxt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/caveat_semibold"
                android:text="✨Welcome to our Ecommerce application, a simple user friendly platform designed to make online shopping easy and accessible for everyone. Users can quickly create accounts, securely log in and browse a wide range of products with detailed description and the product photo. Our seemly checkout process allows customers to pay conviniently by use of Mpesa. We are happy and look forward working and doing bussiness with you."
                android:textAlignment="center"
                android:textColor="#fff"
                android:textSize="24sp" />

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:id="@+id/btnListen"
                android:textColor="#fff"
                android:layout_marginRight="50dp"
                android:layout_marginLeft="50dp"
                android:text="🎤 Know Us"
                android:textSize="23sp"
                android:backgroundTint="#882B3E50"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>