<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:background="#0F2D4B"
    android:layout_height="match_parent"
    tools:context=".PaymentActivity">

<!--    Below is text View-->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Complete Payment With M-pesa"
        android:textSize="29sp"
        android:textAlignment="center"
        android:layout_marginTop="10dp"
        android:textStyle="bold"
        android:textColor="#F326A426"/>

<!--    Below is a card view that holds all our contents-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        app:cardElevation="12dp"
        app:cardCornerRadius="15dp">

<!--        Below is the linear layout-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#0b7766">

<!--Below is a textview where the name of the product shall be binded/attached-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/txtProductName"
                android:text="Product Name"
                android:textSize="20sp"
                android:textStyle="bold|italic"
                android:textColor="#000"/>

<!--            Below is an image view for the product image-->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:id="@+id/imgProduct"
                android:src="@mipmap/ic_launcher"
                android:scaleType="centerCrop"
                android:layout_marginTop="10dp"
                android:layout_marginRight="20dp"
                android:layout_marginLeft="20dp"/>

<!--            Below is a text view for product description-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/txtProductdescription"
                android:text="Product description"
                android:textSize="24sp"
                android:layout_marginTop="10dp"
                android:textStyle="bold|italic"
                android:textColor="#5D3239"/>

<!--            Below is the textView for the product_cost-->
           <TextView
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:id="@+id/txtProductCost"
               android:text="Kes 1000"
               android:textSize="29sp"
               android:layout_marginTop="8dp"
               android:textStyle="bold"
               android:textColor="#59caa1"
               android:fontFamily="sans-serif-condensed-light"/>

<!--            Below is editText for entering mobile number-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/phone"
                android:hint="Enter your phone number e.g 2547********"
                android:textColorHint="#000"
                android:textColor="#000"
                android:padding="15dp"
                android:layout_marginTop="10dp"
                android:background="#cc68bb" />

<!--            Below is a button to complete the payment action-->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/pay"
                android:text="Pay Now"
                android:layout_marginTop="25dp"
                android:layout_marginLeft="70dp"
                android:layout_marginRight="70dp"
                android:backgroundTint="#cc68bb"
                android:textColor="#fff"
                android:textSize="18sp"/>



        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>