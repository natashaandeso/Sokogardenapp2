<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:background="#F48FB1"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/shape"
        android:fontFamily="cursive"
        android:text=" 🌸Sokogarden🌸"
        android:textAlignment="center"
        android:textColor="#F13A4D5F"
        android:textSize="45sp"
        android:textStyle="bold|italic" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="120dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="10dp"
        android:layout_margin="10dp"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="#AA78D7"
            android:padding="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=" 🎀Welcome To SokoGarden🎀"
                android:textSize="30sp"
                android:textAlignment="center"
                android:fontFamily="casual"
                android:paddingTop="10dp"
                android:textColor="#000"/>


        </LinearLayout>

    </androidx.cardview.widget.CardView>


<!--    Below is a linear layout that aligns contents horizontally-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👤 Signup"
            android:textSize="25sp"
            android:padding="10dp"
            android:layout_marginLeft="40dp"
            android:layout_marginTop="8dp"
            android:textColor="#234"
            android:backgroundTint="#555F91C8"
            android:id="@+id/signupBtn"/>

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👨‍💼 Signin"
            android:textSize="25sp"
            android:padding="10dp"
            android:layout_marginLeft="40dp"
            android:layout_marginTop="8dp"
            android:textColor="#234"
            android:backgroundTint="#555F91C8"
            android:id="@+id/signinBtn"/>


    </LinearLayout>

<!--    Below is our progress bar-->
    <ProgressBar
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/progressbar"/>

<!--    Below is our recyclerview-->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="602dp"
        tools:listitem="@layout/single_item" />


</LinearLayout>